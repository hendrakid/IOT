# Database connection (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/smartlock

# JWT secret — use a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# Server port
PORT=3000

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# Node environment: development | production
NODE_ENV=development

# SSE: registration scanner access point IDs (comma-separated)
# User Management uses include=; Access Logs & Dashboard use exclude=
SSE_REGISTRATION_ACCESS_POINT_IDS=1

# MQTT (optional — hardware telemetry/status; subscriber disabled if unset)
# Dev broker: from repo root run `docker compose up -d`, then `cd web && npm run mqtt:test`
# Set MQTT_ENABLED=false to skip without removing MQTT_URL.
MQTT_URL=mqtt://localhost:1883
# MQTT_ENABLED=false
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=smartlock/ap/+/telemetry
MQTT_STATUS_TOPIC=smartlock/ap/+/status
# Mark DB online=false when last_seen older than threshold (ms interval for job)
STALE_STATUS_THRESHOLD_SEC=120
STALE_STATUS_INTERVAL_MS=60000
